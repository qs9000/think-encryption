{
    "name": "qs9000/think-encryption",
    "description": "ThinkPHP 混合加密插件，支持 RSA+AES 混合加密、密钥轮换",
    "type": "library",
    "keywords": ["thinkphp", "encryption", "rsa", "aes", "hybrid-encryption"],
    "license": "MIT",
    "authors": [
        {
            "name": "qs9000",
            "email": "pengshuiqing@163.com"
        }
    ],
    "require": {
        "php": ">=8.0",
        "topthink/framework": "^8.0"
    },
    "require-dev": {
        "phpunit/phpunit": "13.2.x-dev"
    },
    "autoload": {
        "psr-4": {
            "ThinkEncryption\\": "src/"
        }
    },
    "autoload-dev": {
        "psr-4": {
            "ThinkEncryption\\tests\\": "tests/"
        }
    },
    "extra": {
        "think": {
            "config": {
                "encrypt": "config/encrypt.php"
            },
            "middleware": {
                "encryption": "ThinkEncryption\\middleware\\EncryptionMiddleware"
            }
        }
    },
    "minimum-stability": "dev"
}
